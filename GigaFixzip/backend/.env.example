# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gigafix
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_SSL=false

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
